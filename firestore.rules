rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidSocialPost(data) {
      return data.keys().hasAll(['author', 'authorId', 'content', 'likes', 'comments', 'createdAt'])
        && data.keys().size() <= 8
        && data.author is string && data.author.size() <= 100
        && data.authorId == request.auth.uid
        && data.content is string && data.content.size() <= 1000
        && data.likes is number
        && data.comments is number
        // createdAt logic handled in create rule
        && (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 600000))
        && (!('mediaType' in data) || (data.mediaType in ['image', 'video']));
    }

    match /config/{document} {
      allow read: if true;
    }

    match /socialPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && isValidId(postId)
        && isValidSocialPost(incoming())
        && incoming().createdAt == request.time
        && incoming().likes == 0
        && incoming().comments == 0;
      
      allow update: if isSignedIn() 
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes is number)
        );
      
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
    }
  }
}
